# ============================================================
# .gitignore — Gerbang API Lampung Utara (Decoupled Monorepo)
# ============================================================

# ========================
# BACKEND (Laravel)
# ========================
backend/.env
backend/.env.backup
backend/.env.production
backend/vendor/
backend/node_modules/
backend/storage/*.key
backend/storage/pail/
backend/bootstrap/cache/*.php
backend/public/build/
backend/public/hot
backend/public/storage
backend/public/fonts-manifest.dev.json
backend/.phpunit.result.cache
backend/.phpunit.cache/
backend/auth.json
backend/Homestead.json
backend/Homestead.yaml
backend/_ide_helper.php

# ========================
# FRONTEND
# ========================
frontend/node_modules/
frontend/.env
frontend/.env.local
frontend/.env.production
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local
frontend/dist/
frontend/build/
frontend/.nuxt/
frontend/.output/
frontend/.next/
frontend/out/

# ========================
# GLOBAL / OS
# ========================
*.log
.DS_Store
Thumbs.db

# ========================
# IDE & EDITOR
# ========================
.phpactor.json
.codex/
.cursor/
.idea/
.nova/
.vscode/
.zed/
